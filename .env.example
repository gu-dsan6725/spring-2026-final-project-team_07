# API Keys for DSAN6725 Final Project
# Copy this file to .env and fill in your API keys

# Anthropic (REQUIRED for Claude Haiku - the agent's brain)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Braintrust (REQUIRED for observability and evals - FREE, no credit card required)
# Sign up and get your FREE key at: https://www.braintrust.dev/
BRAINTRUST_API_KEY=your-braintrust-api-key-here

# Braintrust Project Name (REQUIRED)
# This is the project where traces and eval results will appear
BRAINTRUST_PROJECT=project_name:dsan6725_final_project_blue_moy

# Mem0 (REQUIRED - FREE, no credit card required)
# Provides cloud memory storage for your agent
# Sign up and get your FREE key at: https://app.mem0.ai/dashboard
MEM0_API_KEY=your-mem0-api-key-here

# Model selection per agent
# Intake and Orchestrator use Sonnet for open-ended reasoning and memory handling
# Planning and Audit use Haiku for structured tool-call workflows
INTAKE_MODEL=claude-sonnet-4-6
ORCHESTRATOR_MODEL=claude-sonnet-4-6
PLANNING_MODEL=claude-haiku-4-5-20251001
AUDIT_MODEL=claude-haiku-4-5-20251001